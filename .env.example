# =============================================================================
# Covernor Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Database (SQLite for local dev) ---
DATABASE_URL="file:./dev.db"

# --- Authentication ---
# API key used by the Approval Console frontend and admin scripts.
ADMIN_API_KEY="development_admin_key"

# --- LLM Providers (optional — mock fallback used when absent) ---
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
# ACTIVE_LLM_PROVIDER="openai"          # "openai", "anthropic", "ollama", or "custom"
# LLM_MODEL=""                           # Override default model (e.g. "llama3", "gpt-4o", "claude-3-opus-20240229")
# LLM_BASE_URL=""                        # Override API endpoint (e.g. "http://localhost:11434/v1" for Ollama)

# --- Redis (BullMQ orchestrator + velocity guards) ---
# REDIS_HOST="localhost"
# REDIS_PORT="6379"
# REDIS_URL="redis://localhost:6379"

# --- Cryptographic Keys (production only) ---
# ENCRYPTION_MASTER_KEY="<base64-encoded-32-byte-key>"
# KMS_PRIVATE_KEY="<base64-encoded-ECDSA-private-key>"
# KMS_PUBLIC_KEY="<base64-encoded-ECDSA-public-key>"

# --- Webhooks (Meta/Facebook ingestion) ---
# META_VERIFY_TOKEN="your_verify_token"
# META_APP_SECRET="your_app_secret"
